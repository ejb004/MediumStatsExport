{
  "manifest_version": 3,
  "name": "Medium Stats Export",
  "version": "1.0.0",
  "description": "Export your Medium story stats to Excel or CSV with one click.",
  "minimum_chrome_version": "111",
  "permissions": ["tabs", "scripting", "storage", "activeTab"],
  "host_permissions": ["https://medium.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
